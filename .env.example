NODE_ENV=development
LOG_LEVEL=info

API_HOST=0.0.0.0
API_PORT=3000
WORKER_HOST=0.0.0.0
WORKER_PORT=3001
INVENTORY_EXPIRATION_INTERVAL_MS=5000
INVENTORY_EXPIRATION_BATCH_SIZE=100

POSTGRES_DB=zalo_shop
POSTGRES_USER=zalo_shop
POSTGRES_PASSWORD=local_development_only
POSTGRES_RUNTIME_USER=zalo_shop_runtime
POSTGRES_RUNTIME_PASSWORD=local_runtime_only
DATABASE_URL=postgresql://zalo_shop:local_development_only@localhost:5432/zalo_shop?schema=public
DATABASE_RUNTIME_URL=postgresql://zalo_shop_runtime:local_runtime_only@localhost:5432/zalo_shop?schema=public

AUTH_JWT_ISSUER=zalo-shop-local
AUTH_JWT_AUDIENCE=zalo-shop-clients-local
AUTH_JWT_SECRET=local_jwt_secret_replace_before_shared_deployment
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000
PII_ENCRYPTION_KEY=AQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQEBAQE=
PII_HASH_KEY=local_pii_hash_key_replace_before_shared_deployment
ZALO_IDENTITY_PROVIDER=disabled
ZALO_APP_ID=
ZALO_MINI_APP_ID=
ZALO_APP_SECRET=
ZALO_OPEN_API_TIMEOUT_MS=5000
ZALO_TOKEN_METADATA_TTL_SECONDS=300

REDIS_URL=redis://localhost:6379/0

S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=zalo-shop-local
S3_ACCESS_KEY=minio_local
S3_SECRET_KEY=minio_local_development_only
S3_FORCE_PATH_STYLE=true
CONTENT_EXTERNAL_TARGET_HOSTS=

VITE_API_BASE_URL=http://localhost:3000
